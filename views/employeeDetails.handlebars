<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Employee Details</title>
  <style>
    .morning { background: yellow; }
  </style>
</head>
<body>
  <h1>{{employee.name}} ({{employee._id}})</h1>
  <p>Phone: {{employee.phone}}</p>

  <p>
    <a href="/employee/{{employee._id}}/edit">Edit</a> |
    <a href="/">Back</a>
  </p>

  <h2>Shifts</h2>
  <table border="1" cellpadding="6">
    <tr><th>Date</th><th>Start</th><th>End</th></tr>
    {{#each shifts}}
      <tr>
        <td>{{this.date}}</td>
        <td class="{{#if this.isMorning}}morning{{/if}}">{{this.startTime}}</td>
        <td>{{this.endTime}}</td>
      </tr>
    {{/each}}
  </table>
</body>
</html>