<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Edit Employee</title>
</head>
<body>
  <h1>Edit {{employee.name}} ({{employee.employeeId}})</h1>

  <form method="POST" action="/employee/{{employee.employeeId}}/edit">
    <div>
      <label>Name:</label>
      <input name="name" value="{{employee.name}}">
    </div>
    <div>
      <label>Phone:</label>
      <input name="phone" value="{{employee.phone}}">
    </div>
    <button type="submit">Save</button>
  </form>

  <p><a href="/employee/{{employee.employeeId}}">Cancel</a></p>
</body>
</html>