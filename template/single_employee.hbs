<link rel="stylesheet" href="/public/style.css">

<h1>Employee Details</h1>
Name: {{employeeDetails.name}}<br>
Phone: {{employeeDetails.phone}}<br>
<a href="/edit/{{employeeDetails._id}}">Edit Details</a>

<h2>Shifts</h2>
<table>
<thead>
    <tr><th>Date</th><th>Start Time</th><th>End Time</th></tr>
</thead>
<tbody>
    {{#each shifts}}
    <tr>
        <td>{{date}}</td>
        {{#if startEarly}}
            <td class="early-time">{{startTime}}</td>
        {{else}}
            <td>{{startTime}}</td>
        {{/if}}
        <td>{{endTime}}</td>
    </tr>
    {{/each}}
</tbody>
</table>
<br>
<h2>Documents</h2>

<ul>
    {{#each documents}}
        <li>
            <a href="/documents/{{this._id}}">{{this.filename}}</a>
        </li>
    {{/each}}
</ul>
<br>
<h2>Upload Document</h2>
<form method="POST" action="/uploadfile" enctype="multipart/form-data">
    <input type="hidden" name="eid" value="{{employeeDetails._id}}">
    <input type="file" name="submission">
    <input type="submit" value="Upload">
</form>


